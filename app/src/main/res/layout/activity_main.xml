<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_bg"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <!-- Tarjeta de Estado -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="24dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/card_stroke"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="@string/monitoring_label"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="19sp"
                android:letterSpacing="0.1"
                android:gravity="center"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/txtStatusHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:text="@string/status_inactive"
                android:textAlignment="center"
                android:textColor="@color/status_inactive"
                android:textSize="38sp"
                android:textStyle="bold" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Sección Dispositivo Bluetooth -->
    <LinearLayout
        android:id="@+id/layoutDeviceInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/cardStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="@string/bluetooth_device_section"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <!-- Fila: icono BT + Conectado + nombre dispositivo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="6dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_bluetooth"
                app:tint="@color/status_active" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/connected_label"
                android:textColor="@color/text_white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtDeviceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_device_selected"
                android:textColor="@color/status_inactive"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Fila: icono batería + Batería Bluetooth + nivel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="6dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_battery"
                app:tint="@color/status_active" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/battery_bluetooth_label"
                android:textColor="@color/text_white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtBatteryLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/battery_level_unknown"
                android:textColor="@color/status_active"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- Botón 3D -->
    <FrameLayout
        android:id="@+id/btnPanicContainer"
        android:layout_width="220dp"
        android:layout_height="220dp"
        app:layout_constraintTop_toBottomOf="@id/layoutDeviceInfo"
        app:layout_constraintBottom_toTopOf="@id/btnConfig"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnPanic"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null"
            android:src="@drawable/btn_green"
            android:scaleType="fitCenter"
            android:contentDescription="@string/monitoring_label" />

        <TextView
            android:id="@+id/txtBtnAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/start_monitoring_short"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:textSize="22sp"
            android:gravity="center"
            android:maxLines="2"
            android:maxWidth="160dp"
            android:lineSpacingExtra="4dp"
            android:textAlignment="center"
            android:shadowColor="@color/shadow_black"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4" />

    </FrameLayout>

    <!-- Botón de Configuración Inferior -->
    <LinearLayout
        android:id="@+id/btnConfig"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:padding="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_preferences"
            app:tint="@color/text_white"
            android:contentDescription="@string/settings_label" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_label"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:gravity="center" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
