<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/settings_bg_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="64dp"
        android:paddingBottom="8dp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:gravity="center_vertical">
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/settings_text_primary_light"
            android:contentDescription="@string/back_button_description" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/pro_settings_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="@color/settings_text_primary_light" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingBottom="24dp">

            <!-- Descripción -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pro_settings_subtitle"
                android:textColor="@color/settings_text_secondary_light"
                android:textSize="13sp"
                android:paddingTop="8dp"
                android:paddingBottom="16dp" />

            <!-- Permisos -->
            <TextView
                android:id="@+id/txtPermStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:paddingBottom="16dp"
                android:textColor="@color/settings_text_secondary_light" />

            <!-- Switch activar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/pro_email_enabled_label"
                    android:textColor="@color/settings_text_primary_light"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchEmailAlert"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Configuración (visible solo si switch ON) -->
            <LinearLayout
                android:id="@+id/layoutEmailConfig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- SMTP Host -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/pro_smtp_host" android:textColor="@color/settings_text_secondary_light"
                    android:textSize="13sp" android:paddingBottom="4dp"/>
                <EditText android:id="@+id/etSmtpHost" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="textUri"
                    android:hint="smtp.gmail.com" android:textColor="#000000"
                    android:textColorHint="#888888" android:padding="10dp"
                    android:background="@android:drawable/edit_text"
                    android:layout_marginBottom="12dp" />

                <!-- SMTP Port -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/pro_smtp_port" android:textColor="@color/settings_text_secondary_light"
                    android:textSize="13sp" android:paddingBottom="4dp"/>
                <EditText android:id="@+id/etSmtpPort" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="number"
                    android:hint="587" android:textColor="#000000"
                    android:textColorHint="#888888" android:padding="10dp"
                    android:background="@android:drawable/edit_text"
                    android:layout_marginBottom="12dp" />

                <!-- Email remitente -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/pro_smtp_user" android:textColor="@color/settings_text_secondary_light"
                    android:textSize="13sp" android:paddingBottom="4dp"/>
                <EditText android:id="@+id/etSmtpUser" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="textEmailAddress"
                    android:hint="your@gmail.com" android:textColor="#000000"
                    android:textColorHint="#888888" android:padding="10dp"
                    android:background="@android:drawable/edit_text"
                    android:layout_marginBottom="12dp" />

                <!-- Contraseña de app -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/pro_smtp_pass"
                        android:textColor="@color/settings_text_secondary_light" android:textSize="13sp"/>
                    <Button android:id="@+id/btnGmailHelp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/pro_gmail_help"
                        android:textSize="11sp" android:paddingHorizontal="8dp"
                        android:backgroundTint="@color/whatsapp_green" />
                </LinearLayout>
                <EditText android:id="@+id/etSmtpPass" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="textPassword"
                    android:hint="xxxx xxxx xxxx xxxx" android:textColor="#000000"
                    android:textColorHint="#888888" android:padding="10dp"
                    android:background="@android:drawable/edit_text"
                    android:layout_marginBottom="12dp" />

                <!-- Email destino -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/pro_email_to" android:textColor="@color/settings_text_secondary_light"
                    android:textSize="13sp" android:paddingBottom="4dp"/>
                <EditText android:id="@+id/etEmailTo" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="textEmailAddress"
                    android:hint="emergency@contact.com" android:textColor="#000000"
                    android:textColorHint="#888888" android:padding="10dp"
                    android:background="@android:drawable/edit_text"
                    android:layout_marginBottom="12dp" />

                <!-- Asunto -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/pro_email_subject" android:textColor="@color/settings_text_secondary_light"
                    android:textSize="13sp" android:paddingBottom="4dp"/>
                <EditText android:id="@+id/etEmailSubject" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="text"
                    android:textColor="#000000" android:textColorHint="#888888"
                    android:padding="10dp" android:background="@android:drawable/edit_text"
                    android:layout_marginBottom="12dp" />

                <!-- Mensaje -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/pro_email_body" android:textColor="@color/settings_text_secondary_light"
                    android:textSize="13sp" android:paddingBottom="4dp"/>
                <EditText android:id="@+id/etEmailBody" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="textMultiLine"
                    android:lines="3" android:gravity="top" android:textColor="#000000"
                    android:textColorHint="#888888" android:padding="10dp"
                    android:background="@android:drawable/edit_text"
                    android:layout_marginBottom="16dp" />

                <!-- Adjuntos -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/pro_attachments_label"
                    android:textColor="@color/settings_text_primary_light"
                    android:textSize="15sp" android:textStyle="bold" android:paddingBottom="8dp"/>
                <CheckBox android:id="@+id/cbFrontCam" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="@string/pro_attach_front_cam"
                    android:textColor="@color/settings_text_primary_light" android:checked="true"/>
                <CheckBox android:id="@+id/cbRearCam" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="@string/pro_attach_rear_cam"
                    android:textColor="@color/settings_text_primary_light" android:checked="true"/>
                <CheckBox android:id="@+id/cbAudio" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="@string/pro_attach_audio"
                    android:textColor="@color/settings_text_primary_light"
                    android:checked="true" android:layout_marginBottom="16dp"/>

                <!-- Cuándo enviar -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/pro_when_label"
                    android:textColor="@color/settings_text_primary_light"
                    android:textSize="15sp" android:textStyle="bold" android:paddingBottom="8dp"/>
                <CheckBox android:id="@+id/cbOnPanic" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="@string/pro_when_panic"
                    android:textColor="@color/settings_text_primary_light" android:checked="true"/>
                <CheckBox android:id="@+id/cbOnBtAlarm" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="@string/pro_when_bt_alarm"
                    android:textColor="@color/settings_text_primary_light"
                    android:checked="true" android:layout_marginBottom="20dp"/>

                <!-- Botones -->
                <Button android:id="@+id/btnTestEmail" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="@string/pro_test_button"
                    android:backgroundTint="@color/settings_text_secondary_light"
                    android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btnSaveEmail" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="@string/pro_save_button"
                    android:backgroundTint="@color/whatsapp_green"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
